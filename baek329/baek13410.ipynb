    "n, k = map(int, input().split())\n",
    "maxx = []\n",
    "for i in range(1, k +1):\n",
    "    num = n * i\n",
    "    reverse_num = int(str(num)[::-1])\n",
    "    maxx.append(reverse_num)\n",
    "print(max(maxx))"
   ]
