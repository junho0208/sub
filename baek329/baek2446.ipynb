   "source": [
    "n = int(input())\n",
    "\n",
    "for i in range(1, n + 1):\n",
    "    print(' '*(i - 1) + '*' * ((n-i) * 2 + 1))\n",
    "for j in range(n - 1, 0, -1):\n",
    "    print(' '*(j - 1) + '*' * ((n-j) * 2 + 1))"
   ]
  }
